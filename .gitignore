# macOS / editor
.DS_Store
*.swp
*.swo

# Runtime logs
*.log
nohup.out

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/

# Large raw and intermediate geospatial data
*.tif
*.tiff
*.tif.ovr
*.tiff.ovr
*.aux.xml
